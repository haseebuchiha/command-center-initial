// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid(2))
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  email           String    @unique @db.Citext
  password        String
  name            String    @db.Citext
  emailVerifiedAt DateTime?

  sessions       Session[]
  passwordResets PasswordReset[]

  agents           Agent[]
  userIntegrations UserIntegration[]
  approvals        Approval[]
  documents        Document[]
  onboardSteps     OnboardStep[]
  tokenUsages      TokenUsage[]
  dailyBriefs      DailyBrief[]
  pipelineRuns     PipelineRun[]
  activityEvents   ActivityEvent[]
  builds           Build[]
  customers        Customer[]
  supportTickets   SupportTicket[]
}

model Session {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  expiresAt DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  token     String   @unique
  expiresAt DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agent {
  id          String        @id @default(cuid())
  name        String
  role        String
  emoji       String
  status      String        @default("idle")
  task        String?
  progress    Int           @default(0)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvals   Approval[]
  tokenUsages TokenUsage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, name])
}

model Integration {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  category         String
  icon             String
  description      String
  popular          Boolean           @default(false)
  authType         String            @default("toggle")
  userIntegrations UserIntegration[]
}

model UserIntegration {
  id                String             @id @default(cuid())
  userId            String
  integrationId     String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  integration       Integration        @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  createdAt         DateTime           @default(now())
  slackInstallation SlackInstallation?

  @@unique([userId, integrationId])
}

model SlackInstallation {
  id                String          @id @default(cuid())
  userIntegrationId String          @unique
  userIntegration   UserIntegration @relation(fields: [userIntegrationId], references: [id], onDelete: Cascade)
  botToken          String
  botUserId         String
  teamId            String
  teamName          String
  appId             String
  installerUserId   String
  scopes            String
  tokenType         String          @default("bot")
  isEnterprise      Boolean         @default(false)
  enterpriseId      String?
  enterpriseName    String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Approval {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type          String
  title         String
  preview       String
  status        String   @default("pending")
  pipelineRunId String?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  title     String
  agentName String
  type      String
  icon      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model OnboardStep {
  id        String  @id @default(cuid())
  label     String
  sortOrder Int
  done      Boolean @default(false)
  skippable Boolean @default(false)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sortOrder])
}

model TokenUsage {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tokens        Int
  date          DateTime @db.Date
  model         String?
  costCents     Int      @default(0)
  pipelineRunId String?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model DailyBrief {
  id        String   @id @default(cuid())
  emoji     String
  title     String
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  createdAt DateTime @default(now())
}

model OrderSubmission {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String
  phone         String?
  bizName       String
  bizDesc       String
  idealCustomer String?
  bizType       String
  industry      String?
  goals         String[]
  hasWebsite    Boolean  @default(false)
  currentUrl    String?
  revenueGoal   String?
  theme         String
  inspireUrls   String[]
  colors        String?
  createdAt     DateTime @default(now())
}

model PipelineRun {
  id             String          @id @default(cuid())
  projectName    String
  phase          String
  status         String          @default("running")
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  tokenTotal     Int             @default(0)
  costCents      Int             @default(0)
  errorMessage   String?
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityEvents ActivityEvent[]
  build          Build?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ActivityEvent {
  id            String       @id @default(cuid())
  agentName     String
  agentEmoji    String
  action        String
  label         String
  detail        String?
  color         String       @default("#3B82F6")
  pipelineRunId String?
  pipelineRun   PipelineRun? @relation(fields: [pipelineRunId], references: [id], onDelete: SetNull)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
}

model Build {
  id            String      @id @default(cuid())
  pipelineRunId String      @unique
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  projectName   String
  liveUrl       String?
  status        String      @default("pending")
  platform      String      @default("vercel")
  neonProjectId String?
  durationMs    Int?
  errorLog      String?
  fileCount     Int?
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Customer {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  status    String          @default("active")
  tickets   SupportTicket[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
}

model SupportTicket {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  description String
  status      String   @default("open")
  priority    String   @default("medium")
  createdBy   String   @default("manual")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([customerId])
  @@index([status])
}
